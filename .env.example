# Copy to `.env` for local dev, and set the same keys in Vercel → Project →
# Settings → Environment Variables for production.

# Apollo.io API key (people + org enrichment). Required.
APOLLO_API_KEY=

# Hosted database (Turso / libSQL). Leave BOTH blank for local dev — the app
# falls back to the local ./dev.db file. Set them in Vercel for production.
#   turso db show <name> --url        -> TURSO_DATABASE_URL (libsql://…)
#   turso db tokens create <name>     -> TURSO_AUTH_TOKEN
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Used only by Prisma CLI (studio/migrate) locally. Not needed on Vercel.
DATABASE_URL="file:./dev.db"
